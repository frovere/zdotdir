#!/usr/bin/env zsh

# aliases
alias art=artisan
alias phpunit='composer exec phpunit'
alias grep=rg
alias j=zi
alias kat='bat -p -p'
alias vi='nvim'
alias vim='nvim'
alias zshrc='${EDITOR:-vim} ${ZDOTDIR:-$HOME}/.zshrc'
alias php-cs-fixer='composer exec php-cs-fixer -- fix --config .php-cs-fixer.dist.php'
alias man=tldr
alias htop=btop

# more ways to ls
alias ll='eza -lh --icons --group --created --modified --git'
alias la='eza -lah --icons --group --created --modified --git'
alias ldot='eza -ld -icons --group --created --modified --git .*'
alias tree='eza --tree -a -I .git'

alias c="open $1 -a \"Visual Studio Code\""

function artisan() {
  herd php artisan "$@"
}

function falco() {
  herd php -d memory_limit=-1 falco -n "$@"
}

function composer() {
  herd composer "$@"
}
